rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'riderezzy@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity Validation Helpers
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.total is number && data.total >= 0;
    }

    function isValidReview(data) {
      return data.userId == request.auth.uid &&
             data.productId is string && isValidId(data.productId) &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000;
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 100;
    }

    // 4. Collection Rules
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    // Collections
    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update, delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'profileImage', 'address', 'walletBalance', 'transactions', 'installments', 'membership']);
      allow delete: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if isOwner(existing().userId) && 
                    isValidReview(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isOwner(existing().userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create, delete: if isAdmin();
    }

    // Coupons
    match /coupons/{couponId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    // Admins (Metadata collection)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
