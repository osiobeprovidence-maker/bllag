{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury jewelry item in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "discount": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "isBestSeller": { "type": "boolean" },
        "isNew": { "type": "boolean" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A collection or category of jewelry pieces",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid", "refunded"] },
        "trackingNumber": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review from a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An in-app notification for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order_update", "promotion", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon code",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["code", "discountType", "value", "active"]
    },
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer", "agent"] },
        "profileImage": { "type": "string" },
        "walletBalance": { "type": "number" },
        "transactions": { "type": "array" },
        "installments": { "type": "array" },
        "membership": { "type": "object" },
        "address": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Jewelry products"
    },
    "/collections/{collectionId}": {
      "schema": "Collection",
      "description": "Product collections"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons"
    }
  }
}
