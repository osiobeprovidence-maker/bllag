# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ---- Firebase (Authentication & Firestore) ----
# Set these in Vercel env vars from your Firebase project settings
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="1:xxx:web:xxx"
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_DATABASE_ID="(optional) your-firestore-database-id"

# ---- Convex (Backend) ----
# Local: auto-generated by `npx convex dev` in .env.local
# Production: set via `CONVEX_DEPLOY_KEY` in Vercel env vars.
# The build command in vercel.json handles VITE_CONVEX_URL automatically.
# VITE_CONVEX_URL="https://your-project.convex.cloud"

# ---- Paystack (Payments) ----
VITE_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxx"

# ---- Mux (Video) ----
VITE_MUX_TOKEN_ID="your-mux-token-id"
VITE_MUX_TOKEN_SECRET="your-mux-token-secret"

# ---- Resend (Email) ----
# Used by Convex action to send transactional emails
RESEND_API_KEY="re_xxxxxxxxxxxxx"
