# ---- Clerk (Authentication) ----
VITE_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxx"

# ---- Convex (Backend) ----
# Local: auto-generated by `npx convex dev` in .env.local
# Production: set via `CONVEX_DEPLOY_KEY` in Vercel env vars.
# The build command in vercel.json handles VITE_CONVEX_URL automatically.
# VITE_CONVEX_URL="https://your-project.convex.cloud"

# ---- Paystack (Payments) ----
VITE_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxx"

# ---- Mux (Video) ----
VITE_MUX_TOKEN_ID="your-mux-token-id"
VITE_MUX_TOKEN_SECRET="your-mux-token-secret"

# ---- Resend (Email) ----
# Used by Convex action to send transactional emails
RESEND_API_KEY="re_xxxxxxxxxxxxx"
